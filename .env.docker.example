# ============================================================================
# Docker Environment Configuration Example
# Copy this file to .env and fill in your actual values
# ============================================================================

# AWS S3 Configuration
# Required if downloading model/data from S3
S3_BUCKET=housing-pricing-regression-data
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# API Configuration
# For local development with docker-compose, use http://backend:8000/predict
# For production, set this to your actual backend URL
API_URL=http://backend:8000/predict

# MLFlow Configuration (optional)
MLFLOW_TRACKING_URI=http://127.0.0.1:5000

# Docker Service Ports
# Change these if ports are already in use
BACKEND_PORT=8000
FRONTEND_PORT=8501
